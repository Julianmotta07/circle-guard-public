pipeline {
  agent any
  environment {
    DOCKER_IMAGE = 'julianmotta07/circle-guard-auth'
    SERVICE     = 'circleguard-auth-service'
    NAMESPACE   = 'circle-guard-dev'
  }
  stages {
    stage('Checkout') {
      steps { checkout scm }
    }
    stage('Unit Tests') {
      steps {
        sh './gradlew :services:circleguard-auth-service:test'
      }
      post { always {
        junit '**/build/test-results/test/*.xml'
      }}
    }
    stage('Build JAR') {
      steps {
        sh './gradlew :services:circleguard-auth-service:bootJar -x test'
      }
    }
    stage('Build & Push Docker') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials',
          usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
          sh '/tmp/docker login -u $DOCKER_USER -p $DOCKER_PASS'
          sh '/tmp/docker build -t $DOCKER_IMAGE:dev-${BUILD_NUMBER} -f services/circleguard-auth-service/Dockerfile .'
          sh '/tmp/docker push $DOCKER_IMAGE:dev-${BUILD_NUMBER}'
          sh '/tmp/docker tag $DOCKER_IMAGE:dev-${BUILD_NUMBER} $DOCKER_IMAGE:latest'
          sh '/tmp/docker push $DOCKER_IMAGE:latest'
        }
      }
    }
    stage('Deploy to DEV') {
      steps {
        sh '/tmp/kubectl set image deployment/auth-service auth-service=$DOCKER_IMAGE:dev-${BUILD_NUMBER} -n $NAMESPACE'
        sh '/tmp/kubectl rollout status deployment/auth-service -n $NAMESPACE'
      }
    }
  }
  post {
    success { echo 'Pipeline DEV auth-service completado exitosamente' }
    failure { echo 'Pipeline DEV auth-service fallido' }
  }
}
