pipeline {
  agent any
  environment {
    DOCKER_IMAGE = 'julianmotta07/circle-guard-form'
    NAMESPACE   = 'circle-guard-stage'
  }
  stages {
    stage('Checkout') {
      steps { checkout scm }
    }
    stage('Unit Tests') {
      steps {
        sh './gradlew :services:circleguard-form-service:test'
      }
      post { always {
        junit '**/build/test-results/test/*.xml'
      }}
    }
    stage('Build JAR') {
      steps {
        sh './gradlew :services:circleguard-form-service:bootJar -x test'
      }
    }
    stage('Build & Push Docker') {
      steps {
        withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials',
          usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
          sh '/tmp/docker login -u $DOCKER_USER -p $DOCKER_PASS'
          sh '/tmp/docker build -t $DOCKER_IMAGE:stage-${BUILD_NUMBER} -f services/circleguard-form-service/Dockerfile .'
          sh '/tmp/docker push $DOCKER_IMAGE:stage-${BUILD_NUMBER}'
        }
      }
    }
    stage('Deploy to STAGE') {
      steps {
        sh '/tmp/kubectl apply -f services/circleguard-form-service/k8s/ -n $NAMESPACE'
        sh '/tmp/kubectl set image deployment/form-service form-service=$DOCKER_IMAGE:stage-${BUILD_NUMBER} -n $NAMESPACE'
        sh '/tmp/kubectl rollout status deployment/form-service -n $NAMESPACE'
      }
    }
    stage('Integration Tests') {
      steps {
        sh './gradlew :services:circleguard-form-service:test -Dspring.profiles.active=integration'
      }
      post { always {
        junit '**/build/test-results/test/*.xml'
      }}
    }
  }
  post {
    success { echo 'Pipeline STAGE form-service completado exitosamente' }
    failure { echo 'Pipeline STAGE form-service fallido' }
  }
}
